# App metadata database (migrations, logs, feedback)
DATABASE_URL=postgresql+asyncpg://querymind:querymind_dev@localhost:5432/querymind

# Target database for user queries (read-only role)
TARGET_DATABASE_URL=postgresql://querymind_readonly:readonly_dev@localhost:5432/querymind

# LLM
OPENAI_API_KEY=sk-your-key-here

# Safety thresholds
QUERYMIND_STATEMENT_TIMEOUT=30000
QUERYMIND_MAX_ROWS=1000
QUERYMIND_MAX_EXPLAIN_COST=100000
QUERYMIND_MAX_EXPLAIN_ROWS=500000

# Self-correction loop
QUERYMIND_MAX_RETRIES=3

# Few-shot memory
QUERYMIND_FEW_SHOT_USER_K=3
QUERYMIND_FEW_SHOT_GLOBAL_K=3
